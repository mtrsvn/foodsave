RewriteEngine On

# 1. Redirect /product-management.php to /product-management (External Redirect)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.*)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 2. Allow /product-management to load /product-management.php (Internal Mapping)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]